// Генерация χ² распределения для 10000 значений
chi5 = grand(1, 10000, "chi", 5);   // 5 степеней свободы
chi20 = grand(1, 10000, "chi", 20); // 20 степеней свободы

// Построение двух гистограмм в одном окне
scf();
subplot(1,2,1);
histplot(30, chi5);
xtitle("χ² распределение (5 степеней свободы)", "X", "Частота");

subplot(1,2,2);
histplot(30, chi20);
xtitle("χ² распределение (20 степеней свободы)", "X", "Частота");
