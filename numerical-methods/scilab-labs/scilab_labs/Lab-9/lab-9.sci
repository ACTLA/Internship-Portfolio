// Лабораторная работа 9
// Межотраслевой баланс для пятиотраслевой экономической системы

// 1. Вводим исходные данные задачи
n = 5;

// Матрица коэффициентов прямых затрат A
A = [0.15, 0.10, 0.05, 0.08, 0.03;
     0.12, 0.18, 0.07, 0.05, 0.04;
     0.08, 0.06, 0.12, 0.10, 0.06;
     0.05, 0.04, 0.08, 0.15, 0.07;
     0.03, 0.02, 0.04, 0.06, 0.10];

// Вектор конечной продукции Y
Y = [120; 80; 150; 90; 110];

// Вектор увеличения конечного выпуска продукции ΔY
ΔY = [15; 10; 20; 12; 18];

disp("Матрица A:");
disp(A);
disp("Вектор Y:");
disp(Y);
disp("Вектор ΔY:");
disp(ΔY);

// 2. Проверка продуктивности матрицы A
disp("Суммы элементов столбцов матрицы A:");
for j = 1:n
    sum_col = sum(A(:,j));
    disp("Столбец " + string(j) + ": " + string(sum_col));
end

max_sum = max(sum(A,1));
if max_sum <= 1 & min(sum(A,1)) < 1 then
    disp("Матрица A продуктивна (max сумма = " + string(max_sum) + ")");
else
    disp("Матрица A не продуктивна!");
    abort;
end

// 3. Вычисление матрицы K = E - A
E = eye(n,n);
K = E - A;
disp("Матрица K = E - A:");
disp(K);

// 4. Вычисление матрицы полных затрат S = K^(-1)
S = inv(K);
disp("Матрица полных затрат S:");
disp(S);

// 5. Вычисление вектора валовой продукции X
X = S * Y;
disp("Вектор валовой продукции X:");
disp(X);

// 6. Вычисление матрицы межотраслевых потоков средств производства
X1 = zeros(n,n);
for i = 1:n
    for j = 1:n
        X1(i,j) = A(i,j) * X(j);
    end
end
disp("Матрица межотраслевых потоков X1:");
disp(X1);

// 7. Определение чистой продукции (общие доходы)
O = X' - ones(1,n) * X1;
disp("Вектор чистой продукции O:");
disp(O);

// 8. Вычисление матрицы коэффициентов полных затрат
Aeinv = S;
disp("Матрица коэффициентов полных затрат Aeinv:");
disp(Aeinv);

// 9. Вычисление матрицы косвенных затрат
C = S - A - E;
disp("Матрица косвенных затрат C:");
disp(C);

// 10. Определение изменения плана по заданному вектору увеличения выпуска продукции
ΔX = Aeinv * ΔY;
disp("Изменение валовой продукции ΔX:");
disp(ΔX);

// 11. Формирование таблицы межотраслевого баланса
disp(" ");
disp("ТАБЛИЦА МЕЖОТРАСЛЕВОГО БАЛАНСА");
disp("==============================");

// Заголовок таблицы
header = ["Потребляющие"; "1"; "2"; "3"; "4"; "5"; "Конечная"; "Валовая"];
header = [header; ["отрасли"; ""; ""; ""; ""; ""; "продукция"; "продукция"]];
disp(header');

// Данные по производящим отраслям
for i = 1:n
    row_data = [i, X1(i,1), X1(i,2), X1(i,3), X1(i,4), X1(i,5), Y(i), X(i)];
    row_str = string(row_data);
    disp(row_str);
end

// Чистая продукция
clean_row = ["Чистая"; string(O(1)); string(O(2)); string(O(3)); string(O(4)); string(O(5)); "-"; "-"];
disp(clean_row');

// Валовая продукция
total_row = ["Валовая"; string(X(1)); string(X(2)); string(X(3)); string(X(4)); string(X(5)); "-"; string(sum(X))];
disp(total_row');

// 12. Вывод результатов изменений
disp(" ");
disp("РЕЗУЛЬТАТЫ ИЗМЕНЕНИЙ ПЛАНА");
disp("==========================");
disp("Исходный вектор валовой продукции X:");
disp(X);
disp("Вектор увеличения конечного выпуска ΔY:");
disp(ΔY);
disp("Изменение валовой продукции ΔX:");
disp(ΔX);
disp("Новый вектор валовой продукции X + ΔX:");
disp(X + ΔX);
