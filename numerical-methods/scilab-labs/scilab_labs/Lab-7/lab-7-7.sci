// Задание №7: Генерация зашумленных данных и подгонка модельной функции
// Решение по примеру 8.6 из документа

// 1. Задаем исходную функцию
function y = FF(x, p)
    // Функция вида: y = p(1)*(x - p(2)) + p(3)*x^2
    y = p(1)*(x - p(2)) + p(3)*x.*x;
endfunction

// 2. Параметры, используемые для генерации зашумленных данных
pg = [34; 12; 14];  // Истинные параметры [p1; p2; p3]

// 3. Генерация зашумленных данных
X = [];
Y = [];

// Генерируем данные от 0 до 3 с шагом 0.1
for x = 0:0.1:3
    // Вычисляем значение функции и добавляем шум
    Y = [Y, FF(x, pg) + 100*(rand() - 0.5)];
    X = [X, x];
end

// 4. Построение исходной кривой (без шума)
scf(0); // Первое графическое окно
x_clean = 0:0.01:3;
y_clean = FF(x_clean, pg);
plot(x_clean, y_clean, 'r-', 'linewidth', 2);
xtitle('Исходная функция без шума', 'x', 'y');
xgrid();

// 5. Построение зашумленных данных
scf(1); // Второе графическое окно
plot(X, Y, 'k+', 'markersize', 3);
xtitle('Зашумленные экспериментальные данные', 'x', 'y');
xgrid();

// 6. Подготовка данных для datafit
Z = [Y; X];  // Матрица данных: первая строка - Y, вторая - X

// 7. Определение функции ошибки для подгонки
function e = G(p, z)
    y = z(1);  // Экспериментальное значение Y
    x = z(2);  // Значение X
    e = y - FF(x, p);  // Разность между экспериментальным и модельным значением
endfunction

// 8. Начальное приближение параметров
p0 = [1; 8; 15];  // Начальные значения [p1; p2; p3]

// 9. Выполнение подгонки параметров
[p_opt, err] = datafit(G, Z, p0);

// 10. Вывод результатов
disp("=== РЕЗУЛЬТАТЫ ПОДГОНКИ ===");
disp("Истинные параметры:");
disp("pg = [34; 12; 14]");
disp("Найденные параметры:");
disp("p_opt = [" + string(p_opt(1)) + "; " + string(p_opt(2)) + "; " + string(p_opt(3)) + "]");
disp("Ошибка: " + string(err));

// 11. Построение модельной кривой
scf(2); // Третье графическое окно
plot(X, Y, 'k+', 'markersize', 3); // Зашумленные данные
plot(X, FF(X, p_opt), 'b-', 'linewidth', 2); // Модельная кривая
plot(x_clean, y_clean, 'r--', 'linewidth', 1); // Исходная функция
xtitle('Сравнение экспериментальных данных и модельной кривой', 'x', 'y');
legend(['Зашумленные данные'; 'Модельная кривая'; 'Исходная функция'], 4);
xgrid();

// 12. Сравнение в одном окне всех графиков
scf(3); // Четвертое графическое окно
subplot(2,2,1);
plot(x_clean, y_clean, 'r-', 'linewidth', 2);
xtitle('Исходная функция', 'x', 'y');
xgrid();

subplot(2,2,2);
plot(X, Y, 'k+', 'markersize', 3);
xtitle('Зашумленные данные', 'x', 'y');
xgrid();

subplot(2,2,3);
plot(X, Y, 'k+', 'markersize', 3);
plot(X, FF(X, p_opt), 'b-', 'linewidth', 2);
xtitle('Подгонка модельной кривой', 'x', 'y');
legend(['Данные'; 'Модель'], 4);
xgrid();

subplot(2,2,4);
plot(X, Y, 'k+', 'markersize', 3);
plot(X, FF(X, p_opt), 'b-', 'linewidth', 2);
plot(x_clean, y_clean, 'r--', 'linewidth', 1);
xtitle('Сравнение всех кривых', 'x', 'y');
legend(['Данные'; 'Модель'; 'Истинная'], 4);
xgrid();

// 13. Анализ качества подгонки
Y_model = FF(X, p_opt);
Y_true = FF(X, pg);

// Вычисление среднеквадратичной ошибки
MSE = mean((Y - Y_model).^2);
disp(" ");
disp("=== АНАЛИЗ КАЧЕСТВА ===");
disp("Среднеквадратичная ошибка (MSE): " + string(MSE));

// Вычисление коэффициента детерминации R²
Y_mean = mean(Y);
SS_total = sum((Y - Y_mean).^2);
SS_residual = sum((Y - Y_model).^2);
R_squared = 1 - SS_residual/SS_total;

disp("Коэффициент детерминации R²: " + string(R_squared));

// Вывод отклонений параметров
disp(" ");
disp("Отклонения параметров от истинных значений:");
disp("Δp1 = " + string(p_opt(1) - pg(1)));
disp("Δp2 = " + string(p_opt(2) - pg(2)));
disp("Δp3 = " + string(p_opt(3) - pg(3)));
