// Данные
x = [3.0, 3.1, 3.2, 3.3, 3.4, 3.5, 3.6, 3.7, 3.8];
y = [0.632, 0.600, 0.592, 0.580, 0.589, 0.585, 0.583, 0.569, 0.571];

// Линейная интерполяция
xi = 3.0:0.05:3.8;
yi = interpln([x; y], xi);

// График
scf();
plot(x, y, 'ro', 'markersize', 8);  // Исходные точки
plot(xi, yi, 'b-', 'linewidth', 2); // Интерполяция
xtitle('Линейная интерполяция (задание 1.1)');
xlabel('X'); ylabel('Y');
legend('Исходные данные', 'Линейная интерполяция', 2);
xgrid();
