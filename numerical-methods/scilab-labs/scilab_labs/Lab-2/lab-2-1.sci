// 1) y = x² - 2x + 4
x1 = -10:0.1:10;
y1 = x1.^2 - 2*x1 + 4;
plot(x1, y1, 'r-');

scf();

// 2) y = 2x - 3
x2 = -5:0.5:5;
y2 = 2*x2 - 3;
plot(x2, y2, 'r-');

scf();

// 3) y = (2x² + 5)/(3x²)
x3 = -6:0.1:6;
x3(x3==0) = 0.001; // избегаем деления на 0
y3 = (2*x3.^2 + 5)./(3*x3.^2);
plot(x3, y3, 'r-');

scf();

// 4) y = x³ + 2x
x4 = -10:0.2:10;
y4 = x4.^3 + 2*x4;
plot(x4, y4, 'r-');
