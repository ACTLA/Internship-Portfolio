// Задание 2.
// Задаем матрицы
A = [3, 2, 1; 0, 5, 6; 1, 4, 2]
B = [1, 3, 2; 5, 6, 4; 2, 3, 1]
C = [5, 1, 2; 4, 1, 3; 7, 8, 1]

// Вычисления
A + B
A - B
A ./ C
A / B
A ./ B
C + B - A
A \ B
C .\ A
inv(A)
C * B^2
A .* C
A * 5
B / 2
(A + B) * C
C .^ 3

// Задание 3.
// 1) Определители
det(A)
det(B)

// 2) Ранг матрицы C
rank(C)

// 3) Объединение матриц
cat(2, A, C)
cat(1, A, C)

// 4) Сумма элементов C
sum(C)

// 5) Сумма по столбцам и строкам B
sum(B, 'r')
sum(B, 'c')

// 6) Произведение всех элементов A
prod(A)

// 7) Произведение по столбцам и строкам C
prod(C, 'r')
prod(C, 'c')

// 8) Максимальный и минимальный элементы A
max(A)
min(A)

// 9) Максимальный и минимальный по строкам C
max(C, 'c')
min(C, 'c')

// 10) Максимальный и минимальный по столбцам B
max(B, 'r')
min(B, 'r')

// 11) Приведение A к треугольной форме
rref(A)

// 12) Количество элементов B
length(B)

// 13) Преобразование C в матрицу 1x9
matrix(C, 1, 9)

// 14) Обратная матрица A
inv(A)

// 15) Размер матрицы B
[n, m] = size(B)
n
m

