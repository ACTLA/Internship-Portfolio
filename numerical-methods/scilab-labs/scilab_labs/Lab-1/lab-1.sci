// 1) Матрица Гильберта 5x5
invhilb(5)

// 2) Матрица Франка 3x3
frank(3)

// 3) Единичная матрица 4x4
eye(4, 4)

// 4) Случайная матрица 4x4
rand(4, 4)

// 5) Вектор-строка (2, 4, 6, 8, 10)
[2:2:10]

// 6) Нулевая матрица 4x2
zeros(4, 2)

