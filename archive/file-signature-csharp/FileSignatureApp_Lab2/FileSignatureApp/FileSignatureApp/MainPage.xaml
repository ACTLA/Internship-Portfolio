<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FileSignatureApp.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="30">
            <Label Margin="20" Text="Выберите файл для создания MD5 подписи" 
               FontSize="20"
               HorizontalOptions="Center" />

            <Button Margin="20" Text="Выбрать файл" Clicked="OnPickFileClicked" />

            <Label Margin="20" x:Name="filePathLabel"
               Text="Файл не выбран"
               FontSize="16"
               HorizontalOptions="Center" />

            <Button x:Name="createSignatureButton" Margin="20" Text="Создать электронную подпись" Clicked="OnCreateSignatureClicked"
                IsEnabled="False" />

            <Label Margin="20" x:Name="signatureLabel"
               FontSize="16"
               HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
